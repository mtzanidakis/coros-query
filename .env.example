# Copy to .env and fill in your credentials.
# .env is gitignored; .env.example is safe to commit.

# Coros Training Hub account (required)
COROS_EMAIL=you@example.com
COROS_PASSWORD=your-coros-password

# User ID used in the yfheader. Leave empty to auto-detect from the login
# response; set explicitly if auto-detection fails.
COROS_USER_ID=

# Region: eu | us | cn (default: eu)
COROS_REGION=eu
